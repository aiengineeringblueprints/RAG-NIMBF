# ─── Shared defaults (used when per-role vars are not set) ─────
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# ─── OpenAI-compatible endpoint ───────────────────────────────
# For vLLM, TGI, LM Studio, or any OpenAI-compatible server.
# OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# OPENAI_COMPAT_API_KEY=

# ─── Per-role URL overrides ──────────────────────────────────
# Each falls back to the shared default above if left unset.
# Use these when different models run on different machines.

# Generator LLM (question answering) — overrides shared OLLAMA/OPENAI_COMPAT URLs
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_API_KEY=
# LLM_OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# LLM_OPENAI_COMPAT_API_KEY=

# Critic LLM (RAGAS evaluation) — overrides shared OLLAMA/OPENAI_COMPAT URLs
# EVAL_CRITIC_OLLAMA_BASE_URL=http://dgx-spark:11434
# EVAL_CRITIC_OLLAMA_API_KEY=
# EVAL_CRITIC_OPENAI_COMPAT_BASE_URL=https://rtx-server/v1
# EVAL_CRITIC_OPENAI_COMPAT_API_KEY=

# Embeddings (always Ollama) — overrides shared OLLAMA URL
# EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_OLLAMA_API_KEY=

# ─── Models ───────────────────────────────────────────────────
# Use "ollama:" or "openai:" prefix to pick the provider.
# No prefix defaults to ollama (local or remote, depending on URL config).
LLM_MODELS=ollama:gemma3:4b
# LLM_MODELS=ollama:gemma3:4b,openai:Qwen/Qwen3-32B-AWQ

# Embedding models — use "ollama:" (default) or "huggingface:" prefix.
# HuggingFace models run locally in-process (no server needed).
EMBEDDING_MODELS=nomic-embed-text:latest
# EMBEDDING_MODELS=huggingface:BAAI/bge-small-en-v1.5
CHUNK_SIZES=1000
CHUNK_OVERLAPS=200
CHUNKING_STRATEGIES=recursive
RETRIEVAL_TOP_K=5
MAX_NEW_TOKENS=256

# ─── Prompt templates ──────────────────────────────────────────
# Comma-separated list of prompt template names to sweep.
# Built-in templates: concise (raw values), detailed (full sentences).
# PROMPT_TEMPLATES=concise,detailed
PROMPT_TEMPLATES=concise

# ─── Reranker (optional) ──────────────────────────────────────
# Use "huggingface:" prefix for local cross-encoder rerankers.
# Leave empty / unset to disable reranking.
# RERANKER_MODELS=huggingface:cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_TOP_K=3

# ─── Dataset ──────────────────────────────────────────────────
# Available: t2-ragbench, ragbench, squad
# RAGBench subsets: covidqa, cuad, delucionqa, emanual, expertqa,
#   finqa, hagrid, hotpotqa, msmarco, pubmedqa, tatqa, techqa
# DATASET_NAME=t2-ragbench
DATASET_SUBSET=FinQA
DATASET_SAMPLE_SIZE=50

# ─── RAGAS evaluation critic ─────────────────────────────────
EVAL_CRITIC_LLM=ollama:gemma3:12b
EVAL_CRITIC_EMBEDDING=nomic-embed-text:latest
EVAL_CRITIC_MAX_TOKENS=4096

# ─── MLflow tracking ─────────────────────────────────────────
# Local file store (default – no server needed):
#   MLFLOW_TRACKING_URI=mlruns
# Or a full tracking server:
#   MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_URI=mlruns
